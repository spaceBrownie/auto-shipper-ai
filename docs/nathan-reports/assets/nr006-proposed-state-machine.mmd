flowchart TD
    subgraph AUTO["Auto-Advance Zone"]
        direction TB
        A["<b>Phase 1: Discovery</b><br/>Script loads instructions<br/>Explore + gap analysis"] -->|"Auto"| B["<b>Phase 2: Specification</b><br/>Script loads instructions<br/>Write spec.md"]
        B -->|"Auto"| C["<b>Phase 3: Planning</b><br/>Script loads instructions<br/>Write implementation plan"]
        C -->|"Auto"| D["<b>Phase 4: Test Spec</b><br/>Script loads instructions<br/>Write test-spec.md<br/><i>not 65 test files</i>"]
    end

    D --> GATE1

    GATE1{{"HUMAN GATE<br/>Denny reviews spec,<br/>plan, and test spec"}}

    GATE1 -->|"Approved"| MC["<b>Strategy Engine</b><br/>Recommends agents,<br/>chunking, mode"]
    MC -->|"Binding"| E

    subgraph IMPL["Autonomous Execution — Strategy Engine Drives"]
        direction TB
        E["<b>Phase 5: Implementation</b><br/>Parallel agents per recommendation<br/>TDD: write test, implement, repeat"] --> EE["<b>E2E Test Playbook</b><br/>Verify real behavior<br/>end-to-end"]
    end

    EE --> GATE2

    GATE2{{"HUMAN GATE<br/>Denny reviews code,<br/>test results"}}

    GATE2 -->|"Approved"| F["<b>Phase 6: PR + Review</b><br/>Commit, push, open PR"]
    F --> UB["Unblocked Reviews"]
    UB --> G{"Comments?"}
    G -->|"Yes"| H["Fix & re-push"]
    G -->|"No"| I(["Merge"])
    H --> G

    subgraph SM["validate-phase.py — State Machine Engine"]
        direction LR
        S1["--phase N<br/>--instructions"] --> S2["Loads from<br/>YAML config"]
        S2 --> S3["Returns ~60 lines<br/>of phase instructions"]
    end

    style AUTO fill:#FFFBEB,stroke:#F59E0B,stroke-width:2px,stroke-dasharray: 5 5
