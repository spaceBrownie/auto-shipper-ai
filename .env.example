# =============================================================================
# Auto Shipper AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# .env is gitignored and will never be committed.
#
# Variables without defaults are REQUIRED for the app to start.
# Variables with defaults (shown in comments) can be omitted for default behavior.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection. docker-compose.yml provides a local instance.
DB_URL=jdbc:postgresql://localhost:5432/autoshipper
DB_USERNAME=autoshipper
DB_PASSWORD=<your_secure_password>

# Test database (used by ./gradlew test)
TEST_DB_URL=jdbc:postgresql://127.0.0.1:5432/autoshipper_test
TEST_DB_USERNAME=autoshipper
TEST_DB_PASSWORD=<your_secure_password>

# -----------------------------------------------------------------------------
# Spring Profile
# -----------------------------------------------------------------------------
# Omit or set to anything other than "local" to activate real API adapters.
# Set to "local" to use stub adapters (development mode).
# SPRING_PROFILES_ACTIVE=local

# -----------------------------------------------------------------------------
# Shopify (Required for order pipeline)
# -----------------------------------------------------------------------------
# Shopify Admin API base URL — your store's myshopify.com domain
# Get from: Shopify Partners → your dev store → Settings
SHOPIFY_API_BASE_URL=https://<your-store>.myshopify.com

# Admin API access token — created via custom app in Shopify admin
# Get from: Shopify Admin → Settings → Apps → Develop apps → Create app → API credentials
SHOPIFY_ACCESS_TOKEN=<your_shopify_access_token>

# Webhook HMAC signing secret(s) — comma-separated for key rotation
# Get from: Shopify Admin → Settings → Notifications → Webhooks → Signing secret
SHOPIFY_WEBHOOK_SECRETS=<your_shopify_webhook_secret>

# Estimated order value for Shopify platform fee calculation (default: 100.00)
# SHOPIFY_ESTIMATED_ORDER_VALUE=100.00

# -----------------------------------------------------------------------------
# CJ Dropshipping (Required for supplier orders + demand signals)
# -----------------------------------------------------------------------------
# CJ API base URL (default: https://developers.cjdropshipping.com/api2.0/v1)
# CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1

# CJ API access token
# Get from: CJ developer portal → API Management → Access Token
CJ_ACCESS_TOKEN=<your_cj_access_token>

# Default shipping method name for CJ orders (e.g., CJPacket, USPS, etc.)
# Get from: CJ API GET /logistic/freightCalculate or CJ dashboard shipping options
CJ_DEFAULT_LOGISTIC_NAME=<your_cj_logistic_name>

# CJ webhook authentication token (Bearer token for incoming tracking webhooks)
# Set this to a secret you generate; configure the same token in CJ's webhook dashboard
CJ_WEBHOOK_SECRET=<your_cj_webhook_secret>

# -----------------------------------------------------------------------------
# Stripe (Required for payment processing + refunds)
# -----------------------------------------------------------------------------
# Stripe API base URL (default: https://api.stripe.com)
# STRIPE_API_BASE_URL=https://api.stripe.com

# Stripe secret key — use test mode key (sk_test_...) for E2E testing
# Get from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=<your_stripe_secret_key>

# -----------------------------------------------------------------------------
# UPS (Required for carrier rate quotes)
# -----------------------------------------------------------------------------
# UPS API base URL (default: https://onlinetools.ups.com)
# UPS_API_BASE_URL=https://onlinetools.ups.com

# UPS OAuth credentials
# Get from: UPS Developer Portal → My Apps → your app
UPS_CLIENT_ID=<your_ups_client_id>
UPS_CLIENT_SECRET=<your_ups_client_secret>

# -----------------------------------------------------------------------------
# FedEx (Required for carrier rate quotes)
# -----------------------------------------------------------------------------
# FedEx API base URL (default: https://apis.fedex.com)
# FEDEX_API_BASE_URL=https://apis.fedex.com

# FedEx API credentials
# Get from: FedEx Developer Portal → My Projects → your project
FEDEX_CLIENT_ID=<your_fedex_client_id>
FEDEX_CLIENT_SECRET=<your_fedex_client_secret>

# -----------------------------------------------------------------------------
# USPS (Required for carrier rate quotes)
# -----------------------------------------------------------------------------
# USPS API base URL (default: https://api.usps.com)
# USPS_API_BASE_URL=https://api.usps.com

# USPS OAuth token
# Get from: USPS Web Tools API Portal
USPS_OAUTH_TOKEN=<your_usps_oauth_token>

# -----------------------------------------------------------------------------
# YouTube Data API v3 (Required for demand signal scanning)
# -----------------------------------------------------------------------------
# YouTube API base URL (default: https://www.googleapis.com/youtube/v3)
# YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3

# YouTube Data API key
# Get from: Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=<your_youtube_api_key>

# -----------------------------------------------------------------------------
# Reddit API (Required for demand signal scanning)
# -----------------------------------------------------------------------------
# Reddit API base URL (default: https://oauth.reddit.com)
# REDDIT_API_BASE_URL=https://oauth.reddit.com

# Reddit OAuth auth URL (default: https://www.reddit.com/api/v1/access_token)
# REDDIT_AUTH_URL=https://www.reddit.com/api/v1/access_token

# Reddit OAuth credentials
# Get from: Reddit → Preferences → Apps → create app (script type)
REDDIT_CLIENT_ID=<your_reddit_client_id>
REDDIT_CLIENT_SECRET=<your_reddit_client_secret>

# Reddit user agent (default: AutoShipperAI/1.0)
# REDDIT_USER_AGENT=AutoShipperAI/1.0

# -----------------------------------------------------------------------------
# Google Trends (Optional — RSS-based, no API key needed)
# -----------------------------------------------------------------------------
# Geographic filter for Google Trends RSS (default: US)
# GOOGLE_TRENDS_GEO=US

# ── FR-030 dev-store gate-zero (RAT-53) ─────────────────────────────────────
# See docs/live-e2e-runbook.md Section 0 "Pre-flight Key Audit" before enabling.

# HTTP Basic token for the gated /admin/dev/sku/{id}/list endpoint.
# Leave blank in prod. Set to a 16+ char random string for dev-store runs.
DEV_ADMIN_TOKEN=

# Gate for the DevAdminController bean. Keep false in prod.
AUTOSHIPPER_ADMIN_DEV_LISTING_ENABLED=false

# Gate for WebhookArchivalFilter. When true, raw webhook bodies are written to
# docs/fixtures/shopify-dev-store/{date}/ for PM-013 fixture-drift prevention.
AUTOSHIPPER_WEBHOOK_ARCHIVAL_ENABLED=false

# CJ safety gate. When true, CjSupplierOrderAdapter.placeOrder() short-circuits
# with a stub response and makes ZERO HTTP calls. Use when you do NOT have a
# CJ sandbox account (see runbook Section 12 "CJ path selection").
AUTOSHIPPER_CJ_DEV_STORE_DRY_RUN=false
