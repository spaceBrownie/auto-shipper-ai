# Spring Boot
*.pid
spring.pid

# Logs
logs/
*.log

# Compiled output
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
/modules/*/bin/

# Ephemeral webhook archival captures written when tests boot the app
# with the default (non-test-overridden) autoshipper.webhook-archival.output-dir.
# The canonical directory committed to the repo is /docs/fixtures/shopify-dev-store/.
/modules/*/docs/


# Node / Frontend
node_modules/
dist/
frontend/dist/
frontend/.vite/
frontend/node_modules/

# Python (meta_controller scripts)
__pycache__/
*.pyc
*.pyo
.venv/
pyvenv/

# Test reports (keep source, not generated HTML)
app/build/reports/

# Temporary files
*.tmp
*.bak
*.swp
*~
docs/unrelated


# Docker / Colima
.colima/

# Claude Code internals (don't commit session state)
.claude/projects/
.claude/worktrees/
.claude/skills/*-workspace/

# MCP config (local, contains machine-specific paths)
.mcp.json

# Kotlin compiler
.kotlin/

# Playwright MCP
.playwright-mcp/

# Graphify (knowledge graph tool)
.graphify-venv/
.graphify_python
.graphify_detect.json
.graphify_cached.json
.graphify_uncached.txt
.graphify_ast.json
graphify-out/
graphify-workspace

# Claude Code scheduled tasks lock
.claude/scheduled_tasks.lock

# Shopify CLI scaffold — this is a separate deployable, lives outside the monorepo
# Safety net in case the CLI is accidentally run from repo root again
/auto-shipper-ai/
/shopify-app*/
